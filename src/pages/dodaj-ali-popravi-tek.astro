---
import BaseLayout from '../layouts/BaseLayout.astro';

const formUrl = 'https://docs.google.com/forms/d/e/1FAIpQLScBgO8Keau-2cZWHubhacvCmbzLbw0wlroE6-rR6TEJnzfgUw/viewform';
---

<BaseLayout title="Dodaj ali popravi tek" description="Predlagajte nov tek ali popravek podatkov v Slovenskem Tekaškem Koledarju.">
  <main>
    <section class="page-hero container" aria-labelledby="page-title">
      <span class="eyebrow">Predlogi in popravki</span>
      <h1 id="page-title">Dodaj ali popravi tek</h1>
      <p>
        Če v Slovenskem Tekaškem Koledarju manjka prireditev ali opazite napačen podatek, pošljite predlog prek
        obrazca. Najbolj pomaga povezava do uradnega vira.
      </p>
      <div class="cta-row">
        <a class="button button-primary" href={formUrl} target="_blank" rel="noopener noreferrer">
          Oddaj predlog ali popravek
        </a>
        <a class="button button-secondary-light" href="/iskalnik-tekov/">Najprej preverite koledar</a>
      </div>
    </section>

    <section class="section container" aria-labelledby="what-title">
      <div class="section-heading">
        <h2 id="what-title">Kaj lahko pošljete?</h2>
        <p>Pošljite podatke, ki pomagajo, da je koledar čim bolj točen in uporaben.</p>
      </div>
      <div class="guidance-grid guidance-grid-three">
        <article class="info-card guidance-card">
          <h3>Nov tek</h3>
          <p>Pošljite osnovne podatke o teku, ki še ni v koledarju: naziv, datum, kraj, razdalje in povezavo do vira.</p>
        </article>
        <article class="info-card guidance-card">
          <h3>Popravek obstoječega teka</h3>
          <p>Sporočite popravek datuma, kraja, razdalj, ure štarta, povezave do razpisa ali prijav.</p>
        </article>
        <article class="info-card guidance-card">
          <h3>Dodatne informacije</h3>
          <p>
            Dodate lahko tudi informacijo o otroških ali družinskih tekih, odpovedi, spremembi dogodka ali drugi
            pomembni dopolnitvi.
          </p>
        </article>
      </div>
    </section>

    <section class="section container" aria-labelledby="help-title">
      <div class="section-heading compact-heading">
        <h2 id="help-title">Kaj najbolj pomaga?</h2>
        <p>Najhitreje lahko preverimo predloge, ki imajo jasen uradni vir.</p>
      </div>
      <div class="guidance-panel">
        <ul class="guidance-list">
          <li>uradni razpis ali uradna stran dogodka</li>
          <li>prijavni portal</li>
          <li>točen datum, kraj, razdalje in ura štarta</li>
          <li>jasen dokaz za otroške ali družinske teke, kadar gre za družinam prijazen dogodek</li>
        </ul>
      </div>
    </section>

    <section class="section container" aria-labelledby="review-title">
      <div class="section-heading compact-heading">
        <h2 id="review-title">Pred objavo</h2>
      </div>
      <div class="guidance-note">
        <p>
          Predlogi se pred objavo preverijo. STK ne dodaja dogodkov samo na podlagi nejasnih ali neuradnih informacij.
          Pri družinam prijaznih tekih naj bo iz vira jasno razvidno, da obstajajo otroški teki, družinske kategorije ali
          podobna ponudba.
        </p>
      </div>
    </section>

    <section class="section container" aria-labelledby="before-title">
      <div class="section-heading compact-heading">
        <h2 id="before-title">Pred oddajo</h2>
      </div>
      <div class="guidance-panel">
        <ul class="guidance-list checklist-list">
          <li>preverite, ali je tek že v koledarju</li>
          <li>priložite povezavo do vira</li>
          <li>pri popravku napišite, kateri podatek je napačen</li>
          <li>pri novem teku dodajte čim več osnovnih podatkov</li>
        </ul>
      </div>
    </section>

    <section class="section container" aria-labelledby="cta-title">
      <div class="placeholder-panel">
        <span class="eyebrow">Obrazec</span>
        <h2 id="cta-title">Pripravljeni za oddajo?</h2>
        <p>
          Obrazec odpre neposredno Google Form za nov tek ali popravek. Pred oddajo preverite, ali je dogodek že v
          koledarju, in priložite čim bolj zanesljiv vir.
        </p>
        <div class="cta-row">
          <a class="button button-primary" href={formUrl} target="_blank" rel="noopener noreferrer">
            Oddaj predlog ali popravek
          </a>
          <a class="button button-secondary" href="/iskalnik-tekov/">Najprej preverite koledar</a>
        </div>
      </div>
    </section>
  </main>
</BaseLayout>

<style>
  .guidance-grid,
  .guidance-panel,
  .guidance-note {
    margin-top: 18px;
  }

  .guidance-grid {
    display: grid;
    gap: 14px;
  }

  .guidance-card,
  .guidance-panel,
  .guidance-note {
    border: 1px solid rgba(16, 64, 80, 0.1);
    border-radius: var(--radius-md);
    background: rgba(255, 255, 255, 0.86);
    box-shadow: 0 12px 34px rgba(16, 64, 80, 0.07);
  }

  .guidance-card {
    display: grid;
    align-content: start;
    min-height: 100%;
  }

  .compact-heading {
    margin-bottom: 0;
  }

  .guidance-panel,
  .guidance-note {
    padding: 20px;
  }

  .guidance-note {
    background:
      linear-gradient(135deg, rgba(200, 230, 201, 0.5), rgba(255, 255, 255, 0.9)),
      var(--white);
  }

  .guidance-note p {
    margin: 0;
    color: var(--muted);
    line-height: 1.65;
  }

  .guidance-list {
    display: grid;
    gap: 10px 22px;
    margin: 0;
    padding-left: 1.15rem;
    color: var(--muted);
    line-height: 1.55;
  }

  .guidance-list li::marker {
    color: var(--green);
  }

  @media (min-width: 680px) {
    .guidance-list {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
  }

  @media (min-width: 920px) {
    .guidance-grid-three {
      grid-template-columns: repeat(3, minmax(0, 1fr));
    }
  }
</style>
