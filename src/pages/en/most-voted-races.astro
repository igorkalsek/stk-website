---
import BaseLayout from '../../layouts/BaseLayout.astro';

const englishNavItems = [
  { href: '/en/', label: 'Home' },
  { href: '/en/find-races/', label: 'Find' },
  { href: '/en/family-friendly-races/', label: 'Family-friendly' },
  { href: '/en/most-voted-races/', label: 'Most voted' },
  { href: '/en/personal-calendar/', label: 'Calendar' },
  { href: '/en/stk-tekobot/', label: 'STK Tekobot' }
];
---

<BaseLayout
  title="Most Voted Running Races in Slovenia | Run Slovenia Race Calendar"
  description="Upcoming running races in Slovenia with the most runner votes."
  lang="en"
  canonicalPath="/en/most-voted-races/"
  alternateLinks={[
    { lang: 'sl', href: '/najbolj-glasovani-teki/' },
    { lang: 'en', href: '/en/most-voted-races/' }
  ]}
  navItems={englishNavItems}
  brandHref="/en/"
  brandLabel="Slovenski Tekaški Koledar - English home"
  navLabel="Main navigation"
  menuLabel="Menu"
>
  <main>
    <section class="page-hero container" aria-labelledby="top-voted-title">
      <span class="eyebrow">Runner votes</span>
      <h1 id="top-voted-title">Most voted upcoming races</h1>
      <p>Upcoming races with the most runner votes. The ranking is sorted by vote count. If votes are tied, nearer upcoming races come first.</p>
      <p>Vote for a race you would like to highlight in the calendar.</p>
    </section>

    <section class="section container" aria-labelledby="top-filters-title">
      <div class="search-panel">
        <div class="section-heading search-heading">
          <div>
            <h2 id="top-filters-title">Filters</h2>
            <p>Search by race name or town, then choose a month, region or surface.</p>
            <p class="additional-data-note">For entry fees, race-day registration and elevation gain, use <a href="/en/find-races/">Find races</a>.</p>
          </div>
          <p class="result-count" data-result-count>Loading races …</p>
        </div>

        <form class="filters-grid" data-top-form>
          <label class="field field-wide">
            <span>Search</span>
            <input
              type="search"
              name="search"
              placeholder="Race name or town"
              autocomplete="off"
              data-filter="search"
            />
          </label>

          <label class="field">
            <span>Month</span>
            <select name="month" data-filter="month" disabled>
              <option value="">All months</option>
            </select>
          </label>

          <label class="field">
            <span>Region</span>
            <select name="region" data-filter="region" disabled>
              <option value="">All regions</option>
            </select>
          </label>

          <label class="field">
            <span>Surface</span>
            <select name="surface" data-filter="surface" disabled>
              <option value="">All surfaces</option>
            </select>
          </label>

          <button class="button button-small button-secondary-light clear-filters-button" type="button" data-clear-filters>
            Clear filters
          </button>
        </form>
      </div>
    </section>

    <section class="section container" aria-labelledby="top-results-title">
      <div class="section-heading">
        <h2 id="top-results-title">Ranking</h2>
        <p data-top-status>Loading most voted upcoming races …</p>
      </div>
      <div class="search-results" data-top-results aria-live="polite">
        <article class="event-card search-event-card">
          <h3>Loading data</h3>
          <p>Most voted upcoming races will appear here.</p>
          <div class="event-meta">
            <span class="pill">Runner votes</span>
          </div>
        </article>
      </div>
      <div class="search-more" data-top-more hidden>
        <button class="button button-primary" type="button" data-show-more>Show more</button>
      </div>
    </section>
  </main>
</BaseLayout>

<script>
  import { attachAdditionalDataByMasterRow, fetchAdditionalEventData, renderAdditionalDataBlock, type AdditionalEventData } from '../../utils-additional';
  import { buildGoogleCalendarEventUrl, buildIcsDataUrl, buildIcsFilename, buildOutlookCalendarEventUrl } from '../../utils-calendar';
  import { formatEnglishDateBadge, formatEnglishMonthLabel, formatEnglishSurface } from '../../utils-english';
  import { getDisplayEventTitle } from '../../utils-events';
  import { formatSloveneDistances } from '../../utils-slovenian';

  type ApiRecord = Record<string, unknown>;
  type VoteUrlDetails = {
    title: string;
    token: string;
    date: string;
    eventId: string;
  };
  type TopEvent = {
    id: string;
    row: string;
    rank: number;
    date: string;
    dateValue: number;
    month: string;
    title: string;
    displayTitle: string;
    place: string;
    region: string;
    surface: string;
    distances: string;
    startTime: string;
    voteLabel: string;
    voteCount: number | null;
    voteUrl: string;
    noticeUrl: string;
    registrationUrl: string;
    searchText: string;
    additionalData?: AdditionalEventData | null;
  };

  const TOP_API_URL = 'https://stk-master-api.igor-kalsek.workers.dev/top?scope=upcoming&limit=50';
  const MASTER_API_URL = 'https://stk-master-api.igor-kalsek.workers.dev/';
  const ARRAY_KEYS = ['data', 'events', 'items', 'rows', 'results', 'top'];
  const FIELD_CONTAINERS = ['event', 'race', 'data', 'item', 'row', 'fields'];
  const PAGE_SIZE = 30;
  const dateFormatter = new Intl.DateTimeFormat('en-GB', { day: 'numeric', month: 'short', year: 'numeric' });

  const state: { events: TopEvent[]; filtered: TopEvent[]; apiAvailable: boolean; visibleCount: number } = {
    events: [],
    filtered: [],
    apiAvailable: true,
    visibleCount: PAGE_SIZE
  };

  const resultsElement = document.querySelector<HTMLElement>('[data-top-results]');
  const statusElement = document.querySelector<HTMLElement>('[data-top-status]');
  const countElement = document.querySelector<HTMLElement>('[data-result-count]');
  const formElement = document.querySelector<HTMLFormElement>('[data-top-form]');
  const moreElement = document.querySelector<HTMLElement>('[data-top-more]');
  const showMoreButton = document.querySelector<HTMLButtonElement>('[data-show-more]');
  const searchInput = document.querySelector<HTMLInputElement>('[data-filter="search"]');
  const monthSelect = document.querySelector<HTMLSelectElement>('[data-filter="month"]');
  const regionSelect = document.querySelector<HTMLSelectElement>('[data-filter="region"]');
  const surfaceSelect = document.querySelector<HTMLSelectElement>('[data-filter="surface"]');

  const asRecord = (value: unknown): ApiRecord | null =>
    value && typeof value === 'object' && !Array.isArray(value) ? value as ApiRecord : null;

  const toArray = (payload: unknown): ApiRecord[] => {
    if (Array.isArray(payload)) return payload.filter(asRecord) as ApiRecord[];

    const record = asRecord(payload);
    if (!record) return [];

    for (const key of ARRAY_KEYS) {
      const value = record[key];
      if (Array.isArray(value)) return value.filter(asRecord) as ApiRecord[];
    }

    for (const key of ARRAY_KEYS) {
      const nested = asRecord(record[key]);
      if (!nested) continue;
      const rows = toArray(nested);
      if (rows.length) return rows;
    }

    return [];
  };

  const isMissing = (value: unknown) =>
    value === undefined || value === null || String(value).trim() === '';

  const normalizeKey = (key: string) => key.toLowerCase().trim().replace(/[\s_-]+/g, '');

  const getFieldValue = (item: ApiRecord, key: string): string => {
    const exact = item[key];
    if (!isMissing(exact)) return String(exact).trim();

    const wanted = normalizeKey(key);
    for (const [itemKey, value] of Object.entries(item)) {
      if (normalizeKey(itemKey) === wanted && !isMissing(value)) return String(value).trim();
    }

    for (const containerKey of FIELD_CONTAINERS) {
      const nested = asRecord(item[containerKey]);
      if (!nested) continue;
      const nestedValue = getFieldValue(nested, key);
      if (nestedValue) return nestedValue;
    }

    return '';
  };

  const pickFirst = (item: ApiRecord, keys: string[]) => {
    for (const key of keys) {
      const value = getFieldValue(item, key);
      if (value) return value;
    }
    return '';
  };

  const normalize = (value: string) => value.toLocaleLowerCase('sl-SI').normalize('NFKC').replace(/\s+/g, ' ').trim();

  const parseDateValue = (value: string) => {
    if (!value) return Number.NaN;
    const date = new Date(`${value}T00:00:00`);
    return date.getTime();
  };

  const formatDate = (value: string) => {
    const timestamp = parseDateValue(value);
    return Number.isNaN(timestamp) ? value : dateFormatter.format(new Date(timestamp));
  };

  const formatDateBadge = formatEnglishDateBadge;

  const formatPublicTitleForDisplay = getDisplayEventTitle;

  const formatVisibleEventTitle = (title: string) => title.replace(/\s+-\s+/gu, ' – ');

  const formatSurface = formatEnglishSurface;

  const monthLabel = formatEnglishMonthLabel;

  const escapeHtml = (value: string | number) => {
    const characters: Record<string, string> = {
      '&': '&amp;',
      '<': '&lt;',
      '>': '&gt;',
      '"': '&quot;',
      "'": '&#39;'
    };

    return String(value).replace(/[&<>"']/g, (character) => characters[character]);
  };

  const safeUrl = (value: string) => {
    if (!value) return '';
    try {
      const url = new URL(value);
      return ['http:', 'https:'].includes(url.protocol) ? url.href : '';
    } catch {
      return '';
    }
  };

  const decodeParam = (value: string) => {
    try {
      return decodeURIComponent(value.replace(/\+/g, ' ')).trim();
    } catch {
      return value.replace(/\+/g, ' ').trim();
    }
  };

  const parseVoteUrlDetails = (value: string): VoteUrlDetails => {
    const details: VoteUrlDetails = { title: '', token: '', date: '', eventId: '' };
    if (!value) return details;

    const readParam = (name: string) => {
      try {
        const url = new URL(value);
        return url.searchParams.get(name)?.trim() ?? '';
      } catch {
        const match = value.match(new RegExp(`[?&]${name.replace('.', '\\.')}=([^&]+)`));
        return match ? decodeParam(match[1]) : '';
      }
    };

    details.title = readParam('entry.1386641006');
    const tokenAndDate = readParam('entry.11620528');
    const [token = '', date = ''] = tokenAndDate.split('|').map((part) => part.trim());
    details.token = token;
    details.date = date;
    details.eventId = readParam('entry.1006782074') || token;
    return details;
  };

  const getDirectTitle = (item: ApiRecord) => pickFirst(item, ['naziv_prireditve', 'naziv', 'title', 'name']);

  const getReliableVoteCount = (item: ApiRecord): number | null => {
    const candidates = Object.entries(item).filter(([key]) => /vote|vote/i.test(key));

    for (const [key, value] of candidates) {
      if (!/(count|total|votes|glasov|glasovi|score)/i.test(key)) continue;
      if (typeof value === 'number' && Number.isFinite(value) && value > 0) return Math.floor(value);
      if (typeof value !== 'string') continue;

      const trimmed = value.trim();
      if (!/^\d+$/.test(trimmed)) continue;
      const count = Number(trimmed);
      if (Number.isSafeInteger(count) && count > 0) return count;
    }

    return null;
  };

  const eventIdentifierValues = (item: ApiRecord) => [
    'vote_event_id',
    'glasovanje_id',
    'event_id',
    'id_prireditve',
    'id',
    'sifra',
    'oznaka',
    'entry.1006782074',
    'entry_1006782074'
  ].map((key) => getFieldValue(item, key)).filter(Boolean);

  const findSafeMasterMatch = (topEvent: ApiRecord, masterRows: ApiRecord[], voteDetails: VoteUrlDetails) => {
    const voteEventId = normalize(voteDetails.eventId);
    if (voteEventId) {
      const byId = masterRows.find((masterEvent) => eventIdentifierValues(masterEvent).some((value) => normalize(value) === voteEventId));
      if (byId) return byId;
    }

    const titleCandidates = [getDirectTitle(topEvent), voteDetails.title].map(normalize).filter(Boolean);
    if (!titleCandidates.length) return null;

    const exactTitleMatches = masterRows.filter((masterEvent) => titleCandidates.includes(normalize(getDirectTitle(masterEvent))));
    if (exactTitleMatches.length === 1) return exactTitleMatches[0];

    const topDate = pickFirst(topEvent, ['datum', 'date']) || voteDetails.date;
    if (exactTitleMatches.length > 1 && topDate) {
      return exactTitleMatches.find((masterEvent) => getFieldValue(masterEvent, 'datum') === topDate) ?? null;
    }

    return null;
  };

  const buildDisplayTitle = (topEvent: ApiRecord, match: ApiRecord | null, voteDetails: VoteUrlDetails) => {
    const topTitle = getDirectTitle(topEvent);
    if (topTitle) return topTitle;
    if (voteDetails.title) return voteDetails.title;
    return match ? getDirectTitle(match) : 'Naziv teka ni na voljo';
  };

  const enrichValue = (topEvent: ApiRecord, match: ApiRecord | null, keys: string[]) =>
    pickFirst(topEvent, keys) || (match ? pickFirst(match, keys) : '');

  const formatVoteLabel = (count: number | null) => {
    if (!count) return 'Voting open';
    return `${count} ${count === 1 ? 'vote' : 'votes'}`;
  };

  const formatDistances = formatSloveneDistances;

  const formatStartTime = (value: string) => {
    const trimmed = value.trim();
    if (!trimmed) return '';
    const [hours, minutes] = trimmed.split(':');
    if (!hours || !minutes) return trimmed;
    return `${hours.padStart(2, '0')}:${minutes.padStart(2, '0')}`;
  };

  const mapTopEvents = (topRows: ApiRecord[], masterRows: ApiRecord[]) => topRows.map((row, index): TopEvent | null => {
    const voteUrl = safeUrl(pickFirst(row, ['vote_url', 'glasovanje_url', 'url_glasovanje']));
    const voteDetails = parseVoteUrlDetails(voteUrl || pickFirst(row, ['vote_url', 'glasovanje_url', 'url_glasovanje']));
    const match = findSafeMasterMatch(row, masterRows, voteDetails);
    const sourceTitle = buildDisplayTitle(row, match, voteDetails);
    const title = formatPublicTitleForDisplay(sourceTitle);
    const displayTitle = formatVisibleEventTitle(title);
    const date = enrichValue(row, match, ['datum', 'date']) || voteDetails.date;
    const dateValue = parseDateValue(date);
    const place = enrichValue(row, match, ['kraj', 'place']);
    const region = enrichValue(row, match, ['regija', 'region']);
    const surface = enrichValue(row, match, ['tip_podlage', 'podlaga', 'surface']);
    const distances = enrichValue(row, match, ['razdalje_km', 'razdalje', 'distances']);
    const startTime = enrichValue(row, match, ['cas_zacetka', 'start_time', 'startTime']);
    const voteCount = getReliableVoteCount(row);
    const noticeUrl = safeUrl(enrichValue(row, match, ['povezava_razpis', 'razpis_url', 'notice_url']));
    const registrationUrl = safeUrl(enrichValue(row, match, ['povezava_prijava', 'prijava_url', 'registration_url']));
    const masterRow = match ? getFieldValue(match, 'row') : '';

    if (!sourceTitle || sourceTitle === 'Naziv teka ni na voljo') return null;

    return {
      id: voteDetails.eventId || masterRow || `${date}-${sourceTitle}-${index}`,
      row: masterRow,
      rank: index + 1,
      date,
      dateValue,
      month: Number.isNaN(dateValue) ? '' : String(new Date(dateValue).getMonth() + 1),
      title,
      displayTitle,
      place,
      region,
      surface,
      distances,
      startTime,
      voteLabel: formatVoteLabel(voteCount),
      voteCount,
      voteUrl,
      noticeUrl,
      registrationUrl,
      searchText: normalize([sourceTitle, place].filter(Boolean).join(' '))
    };
  }).filter(Boolean) as TopEvent[];


  const renderCalendarOptions = ({ title, date, location = '', noticeUrl = '', registrationUrl = '' }: {
    title: string;
    date: string;
    location?: string;
    noticeUrl?: string;
    registrationUrl?: string;
  }) => {
    const event = { title, date, location, noticeUrl, registrationUrl, language: 'en' as const };
    const googleUrl = buildGoogleCalendarEventUrl(event);
    const icsUrl = buildIcsDataUrl(event);
    const icsFilename = buildIcsFilename(event);
    const outlookUrl = buildOutlookCalendarEventUrl(event);
    if (!googleUrl && !icsUrl && !outlookUrl) return '';

    const options = [
      googleUrl && `<a href="${escapeHtml(googleUrl)}" target="_blank" rel="noopener noreferrer">Google</a>`,
      icsUrl && `<a href="${escapeHtml(icsUrl)}" download="${escapeHtml(icsFilename)}">Apple / iCal</a>`,
      outlookUrl
        ? `<a href="${escapeHtml(outlookUrl)}" target="_blank" rel="noopener noreferrer">Outlook</a>`
        : icsUrl && `<a href="${escapeHtml(icsUrl)}" download="${escapeHtml(icsFilename)}">Outlook / .ics</a>`
    ].filter(Boolean).join('');

    return `
      <details class="calendar-menu">
        <summary class="button button-small button-secondary-light"><span aria-hidden="true">📅</span><span>Add to calendar</span></summary>
        <div class="calendar-menu-options">${options}</div>
      </details>
    `;
  };

  const setStatus = (message: string) => {
    if (!statusElement) return;
    statusElement.textContent = message;
    statusElement.hidden = !message;
  };

  const setCount = (message: string) => {
    if (countElement) countElement.textContent = message;
  };

  const pluralizeEvents = (count: number) =>
    `${count} ${count === 1 ? 'race' : count === 2 ? 'races' : count < 5 ? 'races' : 'races'}`;

  const getFilters = () => ({
    search: normalize(searchInput?.value ?? ''),
    month: monthSelect?.value ?? '',
    region: regionSelect?.value ?? '',
    surface: surfaceSelect?.value ?? ''
  });

  const renderOptions = (
    select: HTMLSelectElement | null,
    values: string[],
    placeholder: string,
    labelFormatter: (value: string) => string = (value) => value
  ) => {
    if (!select) return;
    select.innerHTML = `<option value="">${escapeHtml(placeholder)}</option>${values
      .map((value) => `<option value="${escapeHtml(value)}">${escapeHtml(labelFormatter(value))}</option>`)
      .join('')}`;
    select.disabled = values.length === 0;
  };

  const populateFilters = () => {
    const months = [...new Set(state.events.map((event) => event.month).filter(Boolean))]
      .sort((a, b) => Number(a) - Number(b));
    const regions = [...new Set(state.events.map((event) => event.region).filter(Boolean))]
      .sort((a, b) => a.localeCompare(b, 'sl-SI'));
    const surfaces = [...new Set(state.events.map((event) => event.surface).filter(Boolean))]
      .sort((a, b) => a.localeCompare(b, 'sl-SI'));

    renderOptions(monthSelect, months, 'All months', monthLabel);
    renderOptions(regionSelect, regions, 'All regions');
    renderOptions(surfaceSelect, surfaces, 'All surfaces', formatSurface);
  };

  const renderEmptyState = (title: string, message: string, pill = 'Most voted races', showClearAction = false) => {
    if (!resultsElement) return;
    resultsElement.innerHTML = `
      <article class="event-card search-empty-card">
        <h3>${escapeHtml(title)}</h3>
        <p>${escapeHtml(message)}</p>
        <div class="event-meta">
          <span class="pill">${escapeHtml(pill)}</span>
        </div>
        ${showClearAction ? '<button class="button button-small button-secondary-light empty-clear-button" type="button" data-clear-filters>Clear filters</button>' : ''}
      </article>
    `;
  };

  const renderEvent = (event: TopEvent) => {
    const formattedSurface = formatSurface(event.surface);
    const metaItems = [
      event.place && `<span class="event-chip"><strong>Town:</strong> ${escapeHtml(event.place)}</span>`,
      event.region && `<span class="event-chip"><strong>Region:</strong> ${escapeHtml(event.region)}</span>`,
      formattedSurface && `<span class="event-chip event-chip-surface">${escapeHtml(formattedSurface)}</span>`,
      event.distances && `<span class="event-chip"><strong>Distances:</strong> ${escapeHtml(formatDistances(event.distances))}</span>`,
      event.startTime && `<span class="event-chip"><strong>Start:</strong> ${escapeHtml(formatStartTime(event.startTime))}</span>`
    ].filter(Boolean).join('');

    const calendarOptions = renderCalendarOptions({
      title: event.title,
      date: event.date,
      location: event.place,
      noticeUrl: event.noticeUrl,
      registrationUrl: event.registrationUrl
    });
    const additionalDataBlock = renderAdditionalDataBlock(event.additionalData, escapeHtml, { eventDate: event.date, language: 'en' });
    const links = [
      event.registrationUrl && `<a class="button button-small button-primary" href="${escapeHtml(event.registrationUrl)}" target="_blank" rel="noopener noreferrer"><span class="action-icon" aria-hidden="true">✍️</span><span>Registration</span></a>`,
      event.noticeUrl && `<a class="button button-small button-secondary-light" href="${escapeHtml(event.noticeUrl)}" target="_blank" rel="noopener noreferrer"><span class="action-icon" aria-hidden="true">📄</span><span>Official info</span></a>`,
      event.voteUrl && `<a class="button button-small button-secondary-light" href="${escapeHtml(event.voteUrl)}" target="_blank" rel="noopener noreferrer" aria-label="${escapeHtml(`Vote for ${event.title}`)}"><span class="action-icon" aria-hidden="true">👍</span><span>Vote</span></a>`,
      calendarOptions
    ].filter(Boolean).join('');

    return `
      <article class="event-card search-event-card ranked-event-card">
        <div class="ranked-event-top">
          <span class="rank-badge" aria-label="Ranking">#${escapeHtml(event.rank)}</span>
          <time class="event-card-date" datetime="${escapeHtml(event.date)}" aria-label="${escapeHtml(formatDate(event.date))}">${escapeHtml(formatDateBadge(event.date))}</time>
          <span class="pill pill-orange">${escapeHtml(event.voteLabel)}</span>
        </div>
        <h3 class="search-event-title">${escapeHtml(event.displayTitle)}</h3>
        ${metaItems ? `<div class="event-details">${metaItems}</div>` : ''}
        ${additionalDataBlock}
        ${links ? `<div class="event-actions">${links}</div>` : ''}
      </article>
    `;
  };

  const renderResults = () => {
    if (!state.apiAvailable) {
      setStatus('Race data is currently unavailable. Please try again in a few minutes.');
      setCount('Data unavailable');
      renderEmptyState('Race data is currently unavailable', 'Most voted racesh tekov trenutno ne moremo prikazati. Poskusite znova čez nekaj minut.', 'Calendar');
      if (moreElement) moreElement.hidden = true;
      return;
    }

    if (!state.events.length) {
      setStatus('There are no most voted upcoming races to show.');
      setCount('0 races');
      renderEmptyState('No races to show', 'There are currently no most voted upcoming races to show.', 'Votes');
      if (moreElement) moreElement.hidden = true;
      return;
    }

    const filters = getFilters();
    state.filtered = state.events.filter((event) => {
      if (filters.search && !event.searchText.includes(filters.search)) return false;
      if (filters.month && event.month !== filters.month) return false;
      if (filters.region && event.region !== filters.region) return false;
      if (filters.surface && event.surface !== filters.surface) return false;
      return true;
    });

    const count = state.filtered.length;
    const visibleEvents = state.filtered.slice(0, state.visibleCount);
    const visibleCount = visibleEvents.length;

    setCount(count > visibleCount ? `Showing ${visibleCount} of ${count} voted ${count === 1 ? 'race' : 'races'}` : pluralizeEvents(count));
    setStatus('');

    if (!count) {
      renderEmptyState('No races match the selected filters.', 'Clear filters or use a broader search term.', 'Filters', true);
      if (moreElement) moreElement.hidden = true;
      return;
    }

    if (resultsElement) resultsElement.innerHTML = visibleEvents.map(renderEvent).join('');
    if (moreElement) moreElement.hidden = visibleCount >= count;
  };

  const loadJson = async (url: string) => {
    const response = await fetch(url, { headers: { Accept: 'application/json' } });
    if (!response.ok) throw new Error(`API status ${response.status}`);
    return response.json();
  };

  const loadEvents = async () => {
    setStatus('Loading most voted upcoming races …');

    try {
      const [topPayload, masterPayload, additionalRows] = await Promise.all([
        loadJson(TOP_API_URL),
        loadJson(MASTER_API_URL).catch((error) => {
          console.warn('Most voted races master enrichment skipped', error);
          return [];
        }),
        fetchAdditionalEventData().catch((error) => {
          console.warn('Most voted races additional data skipped', error);
          return [];
        })
      ]);

      state.events = attachAdditionalDataByMasterRow(mapTopEvents(toArray(topPayload), toArray(masterPayload)), additionalRows);
      state.apiAvailable = true;
      populateFilters();
      renderResults();
    } catch (error) {
      console.error('Most voted races API error', error);
      state.apiAvailable = false;
      renderResults();
    }
  };

  const resetVisibleResults = () => {
    state.visibleCount = PAGE_SIZE;
    renderResults();
  };

  const clearFilters = () => {
    formElement?.reset();
    resetVisibleResults();
  };

  formElement?.addEventListener('input', resetVisibleResults);
  formElement?.addEventListener('change', resetVisibleResults);
  formElement?.addEventListener('submit', (event) => {
    event.preventDefault();
    resetVisibleResults();
  });

  showMoreButton?.addEventListener('click', () => {
    state.visibleCount += PAGE_SIZE;
    renderResults();
  });

  document.addEventListener('click', (event) => {
    const target = event.target instanceof Element ? event.target.closest('[data-clear-filters]') : null;
    if (target) clearFilters();
  });

  loadEvents();
</script>
