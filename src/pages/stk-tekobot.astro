---
import BaseLayout from '../layouts/BaseLayout.astro';

const tekobotUrl = 'https://chatgpt.com/g/g-6a04db599d108191b139cab3429ef3fa-stk-tekobot';

const questionExamples = [
  'Kateri teki so ta vikend?',
  'Prikažite družinam prijazne teke v naslednjih 30 dneh.',
  'Kateri trail teki so v Gorenjski?',
  'Kateri teki imajo objavljene prijavnine?',
  'Kateri teki v naslednjih 30 dneh imajo objavljene prijavnine?',
  'Poiščite cenovno ugodne teke v naslednjem mesecu.',
];

const capabilities = [
  'Teki po datumu',
  'Teki po regiji',
  'Družinam prijazni teki',
  'Trail, cestni in gorski teki',
  'Prijavnine in dodatni podatki, kadar so na voljo',
  'Najbolj glasovani teki',
];
---

<BaseLayout title="STK Tekobot" description="Vprašajte koledar po domače: STK Tekobot pomaga tekačem iskati teke v Slovenskem Tekaškem Koledarju z naravnimi vprašanji.">
  <main>
    <section class="container page-hero tekobot-hero" aria-labelledby="tekobot-title">
      <span class="eyebrow">STK Tekobot</span>
      <h1 id="tekobot-title">Vprašajte koledar po domače</h1>
      <p>
        STK Tekobot pomaga tekačem postavljati naravna vprašanja o Slovenskem Tekaškem Koledarju
        in hitreje najti teke po datumu, kraju, tipu prireditve ali drugih podatkih iz koledarja.
      </p>
      <div class="cta-row">
        <a class="button button-primary" href={tekobotUrl} target="_blank" rel="noopener noreferrer">Odprite STK Tekobot</a>
        <a class="button button-secondary tekobot-secondary" href="/iskalnik-tekov/">Odprite iskalnik tekov</a>
      </div>

      <div class="tekobot-onboarding" aria-label="Navodila za uporabo STK Tekobota">
        <article class="onboarding-card">
          <h2>Za uporabo Tekobota</h2>
          <p>
            Za pogovor s STK Tekobotom potrebujete prijavo v ChatGPT. Če računa še nimate, vas bo
            ChatGPT ob odpiranju Tekobota vodil skozi prijavo ali ustvarjanje računa.
          </p>
        </article>

        <article class="onboarding-card">
          <h2>Shranite si Tekobota za kasneje</h2>
          <p>
            Ko Tekobota prvič odprete, si lahko pogovor pripnete v ChatGPT, da ga kasneje hitreje
            najdete.
          </p>
          <ul>
            <li>
              <strong>Na računalniku:</strong> v levi stranski vrstici ChatGPT premaknite miško na
              pogovor, kliknite ⋯ in izberite “Pin chat”.
            </li>
            <li>
              <strong>Na telefonu:</strong> v aplikaciji ChatGPT pridržite pogovor s Tekobotom in
              izberite “Pin chat”.
            </li>
          </ul>
        </article>
      </div>
    </section>

    <section class="container section" aria-labelledby="examples-title">
      <div class="section-heading">
        <h2 id="examples-title">Primeri vprašanj</h2>
        <p>Začnite z vprašanjem, kot bi ga zastavili tekaškemu prijatelju.</p>
      </div>
      <div class="question-list" role="list">
        {questionExamples.map((question) => (
          <div class="question-card" role="listitem">“{question}”</div>
        ))}
      </div>
    </section>

    <section class="container section" aria-labelledby="capabilities-title">
      <div class="section-heading">
        <h2 id="capabilities-title">Kaj lahko vprašate?</h2>
        <p>Tekobot je uporaben za hitro usmerjanje, ko še ne veste točno, kateri tek iščete.</p>
      </div>
      <div class="card-grid card-grid-three">
        {capabilities.map((capability) => (
          <article class="info-card capability-card">
            <h3>{capability}</h3>
          </article>
        ))}
      </div>
    </section>

    <section class="container note-panel" aria-labelledby="before-register-title">
      <h2 id="before-register-title">Preden se prijavite</h2>
      <p>
        Tekobot uporablja podatke iz STK koledarja. Pred prijavo vedno preverite uradni razpis
        organizatorja, ker se lahko podrobnosti prireditve spremenijo.
      </p>
      <p>
        Če opazite napako ali manjkajoč podatek, uporabite stran
        <a href="/dodaj-ali-popravi-tek/">Dodajte ali popravite tek</a>.
      </p>
    </section>
  </main>
</BaseLayout>

<style>
  .tekobot-hero {
    max-width: 900px;
  }

  .tekobot-hero .eyebrow {
    background: rgba(16, 64, 80, 0.1);
    color: var(--deep-teal);
  }

  .tekobot-hero .cta-row {
    margin-top: 6px;
  }

  .tekobot-secondary {
    background: var(--white);
    color: var(--deep-teal);
    box-shadow: inset 0 0 0 1px rgba(16, 64, 80, 0.16);
  }

  .tekobot-onboarding {
    display: grid;
    gap: 12px;
    margin-top: 24px;
  }

  .onboarding-card {
    border: 1px solid rgba(16, 64, 80, 0.1);
    border-radius: var(--radius-md);
    background: rgba(255, 255, 255, 0.9);
    padding: 18px;
    box-shadow: 0 12px 34px rgba(16, 64, 80, 0.06);
  }

  .onboarding-card h2,
  .onboarding-card p,
  .onboarding-card ul {
    margin: 0;
  }

  .onboarding-card h2 {
    color: var(--deep-teal);
    font-size: 1.05rem;
    letter-spacing: -0.02em;
  }

  .onboarding-card p {
    margin-top: 8px;
    color: var(--muted);
    line-height: 1.6;
  }

  .onboarding-card ul {
    display: grid;
    gap: 8px;
    margin-top: 12px;
    padding-left: 20px;
    color: var(--muted);
    line-height: 1.55;
  }

  .onboarding-card strong {
    color: var(--deep-teal);
  }

  .question-list {
    display: grid;
    gap: 12px;
  }

  .question-card {
    border: 1px solid rgba(16, 64, 80, 0.1);
    border-radius: var(--radius-md);
    background: rgba(255, 255, 255, 0.88);
    color: var(--deep-teal);
    font-weight: 800;
    line-height: 1.45;
    padding: 18px;
    box-shadow: 0 12px 34px rgba(16, 64, 80, 0.06);
  }

  .capability-card {
    min-height: 110px;
  }

  .capability-card h3 {
    line-height: 1.25;
  }

  .note-panel {
    display: grid;
    gap: 10px;
    margin-top: 36px;
    border: 1px solid rgba(16, 64, 80, 0.1);
    border-radius: var(--radius-md);
    background:
      linear-gradient(135deg, rgba(200, 230, 201, 0.68), rgba(255, 255, 255, 0.9)),
      var(--white);
    padding: 22px;
    box-shadow: 0 12px 34px rgba(16, 64, 80, 0.07);
  }

  .note-panel h2,
  .note-panel p {
    margin: 0;
  }

  .note-panel h2 {
    color: var(--deep-teal);
    letter-spacing: -0.025em;
  }

  .note-panel p {
    color: var(--muted);
    line-height: 1.65;
  }

  .note-panel a {
    color: var(--deep-teal);
    font-weight: 800;
    text-decoration: underline;
    text-decoration-thickness: 2px;
    text-underline-offset: 3px;
  }

  @media (min-width: 680px) {
    .question-list {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
  }
</style>
