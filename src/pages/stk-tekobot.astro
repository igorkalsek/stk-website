---
import BaseLayout from '../layouts/BaseLayout.astro';

const tekobotUrl = 'https://chatgpt.com/g/g-6a04db599d108191b139cab3429ef3fa-stk-tekobot';
---

<BaseLayout title="STK Tekobot" description="Pomočnik za vprašanja o tekih iz Slovenskega Tekaškega Koledarja.">
  <main>
    <section class="container page-hero">
      <span class="eyebrow">MVP stran</span>
      <h1>STK Tekobot</h1>
      <p>Predstavitvena stran za pomočnika, ki tekačem pomaga najti primerne prireditve.</p>
    </section>
    <section class="container placeholder-panel" aria-label="Status strani">
      <h2>Stran je pripravljena kot osnova.</h2>
      <p>Integracija Tekobota ni del začetnega MVP-ja; stran je pripravljena za kasnejšo povezavo.</p>
      <div class="cta-row">
        <a class="button button-primary" href={tekobotUrl} target="_blank" rel="noopener noreferrer">Odpri STK Tekobot</a>
        <a class="button button-secondary" href="/iskalnik-tekov/">Odpri iskalnik tekov</a>
      </div>
    </section>
  </main>
</BaseLayout>
