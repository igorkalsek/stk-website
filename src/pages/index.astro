---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout>
  <main>
    <section class="hero container" aria-labelledby="hero-title">
      <div class="hero-card">
        <div class="hero-content">
          <span class="eyebrow">Neodvisen pregled tekov po Sloveniji</span>
          <h1 id="hero-title">Poiščite svoj naslednji tek</h1>
          <p class="hero-lead">Pregleden koledar tekaških prireditev po Sloveniji za tekače, družine in organizatorje.</p>
          <p class="hero-sublead">
            Poiščite tek, preverite osnovne informacije in spremljajte potrjene prireditve na enem mestu.
          </p>
          <div class="hero-actions" aria-label="Glavne povezave">
            <div class="cta-row cta-primary-row">
              <a class="button button-primary" href="/iskalnik-tekov/">Poiščite tek</a>
              <a class="button button-primary" href="/osebni-koledar/">Dodajte koledar v telefon</a>
            </div>
            <nav class="hero-secondary-links" aria-label="Dodatne povezave">
              <a href="/druzinam-prijazni-teki/">Družinam prijazni teki</a>
              <a class="hero-secondary-feature-link" href="/skupinski-teki/"><strong>Skupinski teki</strong><span>Poiščite redne tekaške runde, skupnosti in vodene treninge po Sloveniji.</span></a>
              <a href="/najbolj-glasovani-teki/">Glasovani teki</a>
              <a href="/stk-tekobot/">STK Tekobot</a>
              <a href="/dodaj-ali-popravi-tek/">Dodajte ali popravite tek</a>
            </nav>
          </div>
        </div>
      </div>

      <div class="stats-strip" aria-label="Statistika koledarja">
        <article class="stat-card">
          <span class="stat-icon" aria-hidden="true">🏃</span>
          <span class="stat-value" data-stat="confirmed_public_events_total">—</span>
          <span class="stat-label">potrjenih javnih tekaških prireditev</span>
        </article>
        <article class="stat-card">
          <span class="stat-icon" aria-hidden="true">👨‍👩‍👧‍👦</span>
          <span class="stat-value" data-stat="family_friendly_total">—</span>
          <span class="stat-label">družinam prijaznih tekov</span>
        </article>
      </div>
    </section>

    <section class="section container" aria-labelledby="nearest-title">
      <div class="section-heading section-heading-with-action">
        <div>
          <h2 id="nearest-title">Ta teden tečemo</h2>
          <p>Najbližje potrjene tekaške prireditve iz Slovenskega Tekaškega Koledarja.</p>
        </div>
        <a class="button button-secondary-light" href="/iskalnik-tekov/">Poglejte vse teke</a>
      </div>
      <div class="card-grid card-grid-three" data-nearest-events>
        <article class="event-card">
          <h3>Podatke še nalagamo</h3>
          <p>Najbližji teki bodo prikazani tukaj.</p>
          <div class="event-meta">
            <span class="pill">Koledar</span>
          </div>
        </article>
      </div>
      <p class="data-note nearest-search-note">Za prijavnine, prijave na dan, trase in višinske metre odprite <a href="/iskalnik-tekov/">iskalnik tekov</a>.</p>
    </section>

    <section class="section container" aria-labelledby="voted-title">
      <div class="section-heading section-heading-with-action">
        <div>
          <h2 id="voted-title">Najbolj glasovani prihajajoči teki</h2>
          <p>Lestvica izpostavi prihajajoče teke, ki so prejeli največ glasov tekačev.</p>
        </div>
        <a class="button button-secondary-light" href="/najbolj-glasovani-teki/">Poglejte celotno lestvico</a>
      </div>
      <div class="card-grid" data-top-events>
        <article class="event-card">
          <h3>Podatke še nalagamo</h3>
          <p>Najbolj glasovani prihajajoči teki bodo prikazani tukaj.</p>
          <div class="event-meta">
            <span class="pill">Glasovi tekačev</span>
          </div>
        </article>
      </div>
      <p class="data-note" data-status="top">Lestvica je razvrščena po številu glasov. Pri izenačenem številu glasov imajo prednost bližnji prihajajoči teki.</p>
    </section>


    <section class="section container" aria-labelledby="trust-title">
      <article class="info-card trust-card">
        <div>
          <span class="eyebrow eyebrow-light">O koledarju</span>
          <h2 id="trust-title">Zakaj Slovenski Tekaški Koledar?</h2>
          <p>Na enem mestu zbiramo potrjene tekaške prireditve po Sloveniji, povezave do razpisov, prijav in osebnega koledarja. Pred prijavo vedno preverite uradni razpis organizatorja.</p>
          <p class="tekobot-note">STK Tekobot vam pomaga poiskati teke z vprašanji v naravnem jeziku.</p>
        </div>
        <a class="button button-secondary-light" href="/stk-tekobot/">Vprašajte STK Tekobota</a>
      </article>
    </section>

    <section class="section container" aria-labelledby="calendar-cta-title">
      <article class="info-card calendar-cta-card">
        <div>
          <span class="eyebrow eyebrow-light">Osebni koledar</span>
          <h2 id="calendar-cta-title">Dodajte teke v osebni koledar</h2>
          <p>STK lahko spremljate tudi prek osebnega koledarja, kjer se dogodki prikažejo ob vaših drugih obveznostih.</p>
        </div>
        <a class="button button-secondary-light" href="/osebni-koledar/">Navodila za osebni koledar</a>
      </article>
    </section>

    <section class="section container" aria-labelledby="updates-title">
      <div class="section-heading">
        <h2 id="updates-title">Zadnje posodobitve</h2>
        <p>Najnovejše spremembe v koledarju pomagajo hitro preveriti, kaj je bilo dodano ali popravljeno.</p>
      </div>
      <div class="card-grid" data-recent-updates>
        <article class="update-card">
          <h3>Ni še prikazanih posodobitev</h3>
          <p>Zadnje spremembe bodo prikazane tukaj, ko bodo na voljo.</p>
        </article>
      </div>
    </section>

  </main>
</BaseLayout>

<script>
  import { buildGoogleCalendarEventUrl, buildIcsDataUrl, buildIcsFilename, buildOutlookCalendarEventUrl } from '../utils-calendar';
  import { getDisplayEventTitle } from '../utils-events';
  import { formatSloveneDateBadge, formatSloveneVoteCount } from '../utils-slovenian';

  type ApiRecord = Record<string, unknown>;

  const API_BASE = 'https://stk-master-api.igor-kalsek.workers.dev';
  const numberFormatter = new Intl.NumberFormat('sl-SI');
  const dateFormatter = new Intl.DateTimeFormat('sl-SI', { day: 'numeric', month: 'short', year: 'numeric' });

  const ARRAY_KEYS = ['events', 'next_week', 'updates', 'recent_updates', 'recent', 'data', 'items', 'rows', 'changes', 'results'];
  const STATS_CONTAINERS = ['stats', 'totals', 'summary', 'data', 'counts'];
  const TITLE_CONTAINERS = ['event', 'race', 'data', 'item', 'row', 'fields'];
  const enableApiDebug = import.meta.env.DEV;
  const debugEnabled = enableApiDebug && new URLSearchParams(window.location.search).get('debug') === '1';

  const setStatus = (name: string, message: string) => {
    const element = document.querySelector(`[data-status="${name}"]`);
    if (element) element.textContent = message;
  };

  const asRecord = (value: unknown): ApiRecord | null =>
    value && typeof value === 'object' && !Array.isArray(value) ? value as ApiRecord : null;

  const toArray = (payload: unknown): ApiRecord[] => {
    if (Array.isArray(payload)) return payload.filter(asRecord) as ApiRecord[];

    const record = asRecord(payload);
    if (!record) return [];

    for (const key of ARRAY_KEYS) {
      const value = record[key];
      if (Array.isArray(value)) return value.filter(asRecord) as ApiRecord[];
    }

    for (const key of ARRAY_KEYS) {
      const nested = asRecord(record[key]);
      if (!nested) continue;
      const nestedArray = toArray(nested);
      if (nestedArray.length) return nestedArray;
    }

    return [];
  };

  const pick = (item: ApiRecord, keys: string[], fallback = ''): string => {
    for (const key of keys) {
      const value = item[key];
      if (value !== undefined && value !== null && String(value).trim() !== '') return String(value).trim();
    }
    return fallback;
  };

  const valueAtPath = (item: ApiRecord, path: string): unknown => {
    let current: unknown = item;
    for (const part of path.split('.')) {
      const record = asRecord(current);
      if (!record) return undefined;
      current = record[part];
    }
    return current;
  };

  const pickPath = (item: ApiRecord, paths: string[], fallback = ''): string => {
    for (const path of paths) {
      const value = valueAtPath(item, path);
      if (value !== undefined && value !== null && String(value).trim() !== '') return String(value).trim();
    }
    return fallback;
  };

  const normalizeKey = (key: string) => key.toLowerCase().trim().replace(/[\s_-]+/g, '');

  const getVoteUrlTitle = (item: ApiRecord) => {
    if (typeof item?.vote_url !== 'string' || !item.vote_url.trim()) return '';
    try {
      const url = new URL(item.vote_url);
      return url.searchParams.get('entry.1386641006')?.trim() ?? '';
    } catch (error) {
      const match = item.vote_url.match(/[?&]entry\.1386641006=([^&]+)/);
      return match ? decodeURIComponent(match[1].replace(/\+/g, ' ')).trim() : '';
    }
  };


  const getTopEventTitle = (item: ApiRecord) => {
    if (typeof item?.naziv_prireditve === 'string' && item.naziv_prireditve.trim()) {
      return item.naziv_prireditve.trim();
    }

    if (typeof item?.naziv === 'string' && item.naziv.trim()) {
      return item.naziv.trim();
    }

    if (typeof item?.title === 'string' && item.title.trim()) {
      return item.title.trim();
    }

    if (typeof item?.name === 'string' && item.name.trim()) {
      return item.name.trim();
    }

    const event = asRecord(item?.event);
    if (typeof event?.naziv_prireditve === 'string' && event.naziv_prireditve.trim()) {
      return event.naziv_prireditve.trim();
    }

    if (typeof event?.naziv === 'string' && event.naziv.trim()) {
      return event.naziv.trim();
    }

    const race = asRecord(item?.race);
    if (typeof race?.naziv_prireditve === 'string' && race.naziv_prireditve.trim()) {
      return race.naziv_prireditve.trim();
    }

    if (typeof race?.naziv === 'string' && race.naziv.trim()) {
      return race.naziv.trim();
    }

    const data = asRecord(item?.data);
    if (typeof data?.naziv_prireditve === 'string' && data.naziv_prireditve.trim()) {
      return data.naziv_prireditve.trim();
    }

    if (typeof data?.naziv === 'string' && data.naziv.trim()) {
      return data.naziv.trim();
    }

    const voteUrlTitle = getVoteUrlTitle(item);
    return voteUrlTitle || 'Naziv teka ni na voljo';
  };

  const objectKeys = (value: unknown) => asRecord(value) ? Object.keys(value as ApiRecord) : [];

  const describeKeys = (value: unknown) => {
    const record = asRecord(value);
    if (!record) return '—';
    const entries = Object.entries(record).slice(0, 18).map(([key, entryValue]) => {
      const type = Array.isArray(entryValue) ? 'array' : typeof entryValue;
      return `${key}:${type}`;
    });
    return entries.length ? entries.join(', ') : 'brez ključev';
  };

  const rawValueText = (value: unknown) =>
    value === undefined || value === null || String(value) === '' ? 'not detected' : String(value);

  const compactJsonPreview = (value: unknown) => {
    try {
      return JSON.stringify(value, null, 2).slice(0, 1600);
    } catch (error) {
      return 'JSON preview ni na voljo.';
    }
  };

  const isMissing = (value: unknown) =>
    value === undefined || value === null || String(value).trim() === '';

  const rowKey = (value: unknown) => {
    const record = asRecord(value);
    if (!record) return '';
    const row = record.row ?? record.Row ?? record.ROW ?? record.row_number ?? record.rowNumber;
    return row === undefined || row === null ? '' : String(row).trim();
  };

  const getFieldValue = (item: ApiRecord, key: string) => {
    const exact = item[key];
    if (!isMissing(exact)) return String(exact).trim();

    const wanted = normalizeKey(key);
    for (const [itemKey, value] of Object.entries(item)) {
      if (normalizeKey(itemKey) === wanted && !isMissing(value)) return String(value).trim();
    }

    return '';
  };

  const getMasterRows = (payload: unknown): ApiRecord[] => {
    const record = asRecord(payload);
    if (record && Array.isArray(record.data)) return record.data.filter(asRecord) as ApiRecord[];

    const fallbackRows = toArray(payload);
    if (fallbackRows.length) return fallbackRows;

    if (record) {
      for (const value of Object.values(record)) {
        const rows = toArray(value);
        if (rows.length) return rows;
      }
    }

    return [];
  };

  const normalizedText = (value: unknown) =>
    String(value ?? '').trim().toLowerCase().replace(/\s+/g, ' ');

  const fieldMatches = (topEvent: ApiRecord, masterEvent: ApiRecord, key: string) => {
    const topValue = normalizedText(getFieldValue(topEvent, key));
    const masterValue = normalizedText(getFieldValue(masterEvent, key));
    return Boolean(topValue && masterValue && topValue === masterValue);
  };

  const matchScore = (topEvent: ApiRecord, masterEvent: ApiRecord) => {
    const matchingFields = ['datum', 'kraj', 'regija', 'razdalje_km']
      .filter((key) => fieldMatches(topEvent, masterEvent, key)).length;
    const rowMatches = rowKey(topEvent) && rowKey(topEvent) === rowKey(masterEvent);
    const rowScore = rowMatches && matchingFields > 0 ? 2 : 0;
    return rowScore + matchingFields;
  };

  const findMasterMatch = (topEvent: ApiRecord, masterRows: ApiRecord[]) => {
    let bestMatch: ApiRecord | null = null;
    let bestScore = 0;

    for (const masterEvent of masterRows) {
      const score = matchScore(topEvent, masterEvent);
      if (score > bestScore) {
        bestScore = score;
        bestMatch = masterEvent;
      }
    }

    return bestScore >= 3 ? bestMatch : null;
  };

  const copyIfMissing = (target: ApiRecord, source: ApiRecord, key: string) => {
    if (!isMissing(target[key])) return false;
    const sourceValue = getFieldValue(source, key);
    if (!sourceValue) return false;
    target[key] = sourceValue;
    return true;
  };

  const enrichTopEventsFromMaster = (events: ApiRecord[], masterRows: ApiRecord[]) => events.map((event) => {
    const enriched = { ...event };
    const topTitle = getTopEventTitle(event);
    const voteUrlTitle = getVoteUrlTitle(event);
    const match = findMasterMatch(event, masterRows);
    enriched.__master_matched = Boolean(match);
    enriched.__matched_master_row = match ? rowKey(match) : '';
    enriched.__matched_master_title = match ? getFieldValue(match, 'naziv_prireditve') : '';
    enriched.__vote_url_title = voteUrlTitle;
    enriched.__title_source = topTitle !== 'Naziv teka ni na voljo' && topTitle !== voteUrlTitle ? 'top' : 'not detected';

    if (match) {
      const filledTitle = copyIfMissing(enriched, match, 'naziv_prireditve');
      copyIfMissing(enriched, match, 'datum');
      copyIfMissing(enriched, match, 'kraj');
      copyIfMissing(enriched, match, 'regija');
      copyIfMissing(enriched, match, 'tip_podlage');
      copyIfMissing(enriched, match, 'razdalje_km');
      if (filledTitle) enriched.__title_source = 'master';
    }

    if (getTopEventTitle(enriched) === 'Naziv teka ni na voljo' && voteUrlTitle) {
      enriched.naziv_prireditve = voteUrlTitle;
      enriched.__title_source = 'vote_url';
    } else if (getTopEventTitle(enriched) === voteUrlTitle && voteUrlTitle) {
      enriched.__title_source = 'vote_url';
    }

    return enriched;
  });

  const createDebugPanel = () => {
    if (!debugEnabled) return;
    const main = document.querySelector('main');
    if (!main) return;
    main.insertAdjacentHTML('beforeend', `
      <section class="section container api-debug" data-api-debug aria-label="Razvojna diagnostika">
        <details>
          <summary>Razvojna diagnostika</summary>
          <div class="debug-grid">
            <p><strong>/stats loaded:</strong> <span data-debug-stats>no</span></p>
            <p><strong>/top loaded:</strong> <span data-debug-top>no</span></p>
            <p><strong>/top item count:</strong> <span data-debug-top-count>0</span></p>
            <p><strong>First top item keys:</strong> <code data-debug-top-keys>—</code></p>
            <div><strong>First top raw JSON:</strong> <pre class="debug-json" data-debug-top-json>—</pre></div>
            <p><strong>First top raw row:</strong> <code data-debug-top-row>not detected</code></p>
            <p><strong>Top nested keys:</strong> <code data-debug-top-nested>—</code></p>
            <p><strong>Raw naziv_prireditve:</strong> <code data-debug-top-title-raw>not detected</code></p>
            <p><strong>Raw votes_total:</strong> <code data-debug-top-votes-raw>not detected</code></p>
            <p><strong>Master loaded:</strong> <span data-debug-master>no</span></p>
            <p><strong>Master data item count:</strong> <span data-debug-master-count>0</span></p>
            <p><strong>vote_url title fallback:</strong> <code data-debug-vote-url-title>not detected</code></p>
            <p><strong>Matched master row:</strong> <span data-debug-master-match>no</span></p>
            <p><strong>Matched master title:</strong> <code data-debug-master-title>not detected</code></p>
            <p><strong>Detected top title:</strong> <code data-debug-top-title>not detected</code></p>
            <p><strong>Detected title source:</strong> <code data-debug-top-title-source>not detected</code></p>
            <p><strong>Detected top votes:</strong> <code data-debug-top-votes>not detected</code></p>
            <p><strong>/recent_updates loaded:</strong> <span data-debug-recent>no</span></p>
            <p><strong>/recent_updates item count:</strong> <span data-debug-recent-count>0</span></p>
            <p><strong>First recent item keys:</strong> <code data-debug-recent-keys>—</code></p>
          </div>
        </details>
      </section>
    `);
  };

  const setDebug = (target: string, text: string) => {
    if (!debugEnabled) return;
    const element = document.querySelector(`[data-debug-${target}]`);
    if (element) element.textContent = text;
  };

  const setDebugKeys = (target: string, value: unknown) => {
    if (!debugEnabled) return;
    const element = document.querySelector(`[data-debug-${target}-keys]`);
    if (element) element.textContent = describeKeys(value);
  };

  const nestedKeySummary = (item: unknown) => {
    const record = asRecord(item);
    if (!record) return '—';
    const parts = TITLE_CONTAINERS.map((container) => {
      const nested = asRecord(valueAtPath(record, container))
        ?? asRecord(Object.entries(record).find(([key]) => normalizeKey(key) === normalizeKey(container))?.[1]);
      return nested ? `${container}: ${describeKeys(nested)}` : '';
    }).filter(Boolean);
    return parts.length ? parts.join(' | ') : '—';
  };

  const setDebugTopDetails = (items: ApiRecord[], rawItems = items) => {
    if (!debugEnabled) return;
    const first = items[0];
    const rawFirst = rawItems[0];
    setDebug('top-count', String(rawItems.length));
    setDebugKeys('top', rawFirst);
    setDebug('top-json', rawFirst ? compactJsonPreview(rawFirst) : '—');
    setDebug('top-row', rowKey(rawFirst) || 'not detected');
    setDebug('top-nested', nestedKeySummary(rawFirst));
    setDebug('top-title-raw', rawValueText(rawFirst?.naziv_prireditve));
    setDebug('top-votes-raw', rawValueText(rawFirst?.votes_total));
    setDebug('vote-url-title', rawValueText(first?.__vote_url_title ?? getVoteUrlTitle(rawFirst ?? {})));
    setDebug('master-match', first?.__master_matched ? `yes (${rawValueText(first.__matched_master_row)})` : 'no');
    setDebug('master-title', rawValueText(first?.__matched_master_title));
    setDebug('top-title', first ? getTopEventTitle(first) : 'not detected');
    setDebug('top-title-source', first?.__title_source ? String(first.__title_source) : 'not detected');
    setDebug('top-votes', first ? formatVoteCount(getTopEventVotes(first)) : 'not detected');
  };

  const setDebugRecentDetails = (items: ApiRecord[]) => {
    if (!debugEnabled) return;
    setDebug('recent-count', String(items.length));
    setDebugKeys('recent', items[0]);
  };

  const parsePositiveInteger = (value: unknown) => {
    if (value === null || value === undefined) return null;
    const number = Number.parseInt(String(value).trim(), 10);
    return Number.isFinite(number) && number > 0 ? number : null;
  };

  const getTopEventVotes = (item: ApiRecord) =>
    parsePositiveInteger(item?.votes_total)
    ?? parsePositiveInteger(item?.votes_last_7_days)
    ?? parsePositiveInteger(item?.glasovi)
    ?? parsePositiveInteger(item?.votes)
    ?? parsePositiveInteger(item?.vote_count)
    ?? parsePositiveInteger(item?.total_votes);

  const formatVoteCount = (votes: number | null) => {
    if (votes === null) return 'not detected';
    return formatSloveneVoteCount(votes);
  };

  const normalizeVisibleTitleDash = (title: string) => title.replace(/\s+-\s+/g, ' – ');

  const titleForEvent = (event: ApiRecord) => {
    const title = normalizeVisibleTitleDash(getDisplayEventTitle(getTopEventTitle(event)));
    if (title) return title;

    if (import.meta.env.DEV) {
      console.warn('STK top event title missing. Available keys:', objectKeys(event));
    }

    return 'Naziv teka ni na voljo';
  };

  const pickNumber = (item: ApiRecord, keys: string[]): number | null => {
    for (const key of keys) {
      const value = item[key];
      if (value === undefined || value === null || String(value).trim() === '') continue;
      const numberValue = Number(value);
      if (Number.isFinite(numberValue)) return numberValue;
    }
    return null;
  };


  const numberFromStatArray = (items: ApiRecord[], keys: string[]): number | null => {
    for (const item of items) {
      const statName = pick(item, ['key', 'name', 'metric', 'field', 'id']);
      if (!keys.includes(statName)) continue;
      const value = pickNumber(item, ['value', 'count', 'total', 'amount']);
      if (value !== null) return value;
    }
    return null;
  };

  const pickNestedNumber = (payload: unknown, keys: string[]): number | null => {
    const root = asRecord(payload);
    if (!root) return null;

    const direct = pickNumber(root, keys);
    if (direct !== null) return direct;

    const rootArrayValue = numberFromStatArray(toArray(root), keys);
    if (rootArrayValue !== null) return rootArrayValue;

    for (const containerKey of STATS_CONTAINERS) {
      const nested = asRecord(root[containerKey]);
      if (!nested) continue;
      const nestedValue = pickNumber(nested, keys);
      if (nestedValue !== null) return nestedValue;

      const nestedArrayValue = numberFromStatArray(toArray(nested), keys);
      if (nestedArrayValue !== null) return nestedArrayValue;
    }

    return null;
  };

  const formatDate = (value: string) => {
    if (!value) return '';
    const date = new Date(value);
    return Number.isNaN(date.getTime()) ? value : dateFormatter.format(date);
  };


  const formatDateBadge = formatSloveneDateBadge;

  const escapeHtml = (value: string | number) => {
    const characters: Record<string, string> = {
      '&': '&amp;',
      '<': '&lt;',
      '>': '&gt;',
      "'": '&#39;',
      '"': '&quot;'
    };
    return String(value).replace(/[&<>'"]/g, (character) => characters[character] ?? character);
  };

  const joinParts = (parts: string[]) => parts.filter(Boolean).join(' · ');

  const normalize = (value: string) => value.toLocaleLowerCase('sl-SI').normalize('NFKC');

  const safeUrl = (value: string) => {
    if (!value) return '';
    try {
      const url = new URL(value);
      return ['http:', 'https:'].includes(url.protocol) ? url.href : '';
    } catch {
      return '';
    }
  };

  const renderCalendarOptions = ({ title, date, location = '', noticeUrl = '', registrationUrl = '' }: {
    title: string;
    date: string;
    location?: string;
    noticeUrl?: string;
    registrationUrl?: string;
  }) => {
    const event = { title, date, location, noticeUrl, registrationUrl };
    const googleUrl = buildGoogleCalendarEventUrl(event);
    const icsUrl = buildIcsDataUrl(event);
    const icsFilename = buildIcsFilename(event);
    const outlookUrl = buildOutlookCalendarEventUrl(event);
    if (!googleUrl && !icsUrl && !outlookUrl) return '';

    const options = [
      googleUrl && `<a href="${escapeHtml(googleUrl)}" target="_blank" rel="noopener noreferrer">Google</a>`,
      icsUrl && `<a href="${escapeHtml(icsUrl)}" download="${escapeHtml(icsFilename)}">Apple / iCal</a>`,
      outlookUrl
        ? `<a href="${escapeHtml(outlookUrl)}" target="_blank" rel="noopener noreferrer">Outlook</a>`
        : icsUrl && `<a href="${escapeHtml(icsUrl)}" download="${escapeHtml(icsFilename)}">Outlook / .ics</a>`
    ].filter(Boolean).join('');

    return `
      <details class="calendar-menu">
        <summary class="button button-small button-secondary-light"><span aria-hidden="true">📅</span><span>V koledar</span></summary>
        <div class="calendar-menu-options">${options}</div>
      </details>
    `;
  };



  const nestedEventPaths = (field: string) => [
    field,
    `event.${field}`,
    `race.${field}`,
    `data.${field}`,
    `item.${field}`,
    `row.${field}`,
    `fields.${field}`
  ];

  const getEventTitle = (event: ApiRecord, fallback = 'Naziv teka ni na voljo') =>
    pickPath(event, [
      ...nestedEventPaths('naziv_prireditve'),
      ...nestedEventPaths('naziv'),
      ...nestedEventPaths('title'),
      ...nestedEventPaths('name')
    ], fallback);

  const getEventField = (event: ApiRecord, field: string, aliases: string[] = []) =>
    pickPath(event, [
      ...nestedEventPaths(field),
      ...aliases.flatMap(nestedEventPaths)
    ], '');

  async function loadJson(path: string): Promise<unknown> {
    const response = await fetch(`${API_BASE}${path}`, { headers: { accept: 'application/json' } });
    if (!response.ok) throw new Error(`API request failed: ${response.status}`);
    return response.json();
  }


  async function loadNearestEvents() {
    const container = document.querySelector('[data-nearest-events]');
    if (!container) return;

    try {
      const payload = await loadJson('/');
      const today = new Date();
      const todayValue = new Date(today.getFullYear(), today.getMonth(), today.getDate()).getTime();
      const events = toArray(payload)
        .filter((event) => {
          const date = getEventField(event, 'datum', ['date', 'event_date', 'Datum']);
          const dateValue = new Date(`${date}T00:00:00`).getTime();

          return (
            /^2026-/.test(date) &&
            Number.isFinite(dateValue) &&
            dateValue >= todayValue &&
            normalize(getEventField(event, 'status_dogodka')) === 'potrjeno' &&
            getEventField(event, 'vidno_v_javnem_koledarju').toLocaleUpperCase('sl-SI') === 'DA'
          );
        })
        .sort((a, b) => {
          const dateA = getEventField(a, 'datum', ['date', 'event_date', 'Datum']);
          const dateB = getEventField(b, 'datum', ['date', 'event_date', 'Datum']);
          const dateDifference = new Date(`${dateA}T00:00:00`).getTime() - new Date(`${dateB}T00:00:00`).getTime();
          if (dateDifference !== 0) return dateDifference;

          const placeDifference = getEventField(a, 'kraj', ['place', 'city', 'location']).localeCompare(getEventField(b, 'kraj', ['place', 'city', 'location']), 'sl-SI');
          if (placeDifference !== 0) return placeDifference;

          return getEventTitle(a).localeCompare(getEventTitle(b), 'sl-SI');
        });
      const visibleEvents = events.slice(0, 6);

      if (!events.length) {
        container.innerHTML = `
          <article class="event-card">
            <h3>Trenutno ni prikazanih najbližjih tekov</h3>
            <p>Preverite iskalnik tekov za širši pregled koledarja.</p>
            <div class="event-meta">
              <a class="pill" href="/iskalnik-tekov/">Poglejte vse teke</a>
            </div>
          </article>
        `;
        setStatus('nearest', 'Trenutno ni prikazanih potrjenih prihajajočih javnih tekov.');
        return;
      }

      const eventCards = visibleEvents.map((event) => {
        const sourceTitle = getEventTitle(event);
        const title = getDisplayEventTitle(sourceTitle);
        const dateValue = getEventField(event, 'datum', ['date', 'event_date', 'Datum']);
        const date = formatDate(dateValue);
        const location = getEventField(event, 'kraj', ['place', 'city', 'location']);
        const region = getEventField(event, 'regija', ['region']);
        const noticeUrl = safeUrl(getEventField(event, 'povezava_razpis', ['notice_url', 'razpis_url']));
        const registrationUrl = safeUrl(getEventField(event, 'povezava_prijava', ['registration_url', 'prijava_url']));
        const calendarOptions = renderCalendarOptions({ title, date: dateValue, location, noticeUrl, registrationUrl });
        const summary = joinParts([location, region]);
        const links = [
          noticeUrl && `<a class="button button-small button-secondary-light" href="${escapeHtml(noticeUrl)}" target="_blank" rel="noopener noreferrer"><span class="action-icon" aria-hidden="true">📄</span><span>Razpis</span></a>`,
          registrationUrl && `<a class="button button-small button-primary" href="${escapeHtml(registrationUrl)}" target="_blank" rel="noopener noreferrer"><span class="action-icon" aria-hidden="true">✍️</span><span>Prijava</span></a>`,
          calendarOptions
        ].filter(Boolean).join('');

        return `
          <article class="event-card">
            <div class="event-card-heading">
              <time class="event-card-date" datetime="${escapeHtml(dateValue)}" aria-label="${escapeHtml(date)}">${escapeHtml(formatDateBadge(dateValue))}</time>
              <h3>${escapeHtml(title)}</h3>
            </div>
            ${summary ? `<p>${escapeHtml(summary)}</p>` : ''}
            ${links ? `<div class="event-actions">${links}</div>` : ''}
          </article>
        `;
      }).join('');

      container.innerHTML = eventCards;
      setStatus('nearest', '');
    } catch (error) {
      container.innerHTML = `
        <article class="event-card">
          <h3>Seznam trenutno ni dosegljiv</h3>
          <p>Ko bodo podatki znova na voljo, se bodo najbližji teki prikazali tukaj.</p>
        </article>
      `;
      setStatus('nearest', 'Seznam najbližjih tekov trenutno ni dosegljiv, zato prikazujemo nadomestni prikaz.');
    }
  }

  async function loadStats() {
    try {
      const payload = await loadJson('/stats');
      const confirmedTotal = pickNestedNumber(payload, ['confirmed_public_events_total']);
      const familyTotal = pickNestedNumber(payload, ['family_friendly_total']);
      const values = {
        confirmed_public_events_total: confirmedTotal,
        family_friendly_total: familyTotal
      };

      for (const [key, value] of Object.entries(values)) {
        const element = document.querySelector(`[data-stat="${key}"]`);
        if (element) element.textContent = value === null ? 'Ni podatka' : numberFormatter.format(value);
      }

      setDebug('stats', `yes (${confirmedTotal !== null ? 'confirmed ok' : 'confirmed missing'}, ${familyTotal !== null ? 'family ok' : 'family missing'})`);

      if (confirmedTotal !== null && familyTotal !== null) {
        setStatus('stats', '');
      } else {
        setStatus('stats', 'Ena ali več statističnih vrednosti trenutno manjka.');
      }
    } catch (error) {
      setDebug('stats', 'no');
      setStatus('stats', 'Statistika trenutno ni dosegljiva, zato prikazujemo osnovni pogled.');
    }
  }

  async function loadTopEvents() {
    const container = document.querySelector('[data-top-events]');
    if (!container) return;

    try {
      const payload = await loadJson('/top?scope=upcoming&limit=10');
      const topEvents = toArray(payload).slice(0, 6);
      setDebug('top', 'yes');
      if (!topEvents.length) {
        setDebugTopDetails(topEvents);
        setStatus('top', 'Trenutno ni prikazanih najbolj glasovanih prihajajočih tekov.');
        return;
      }

      let events = topEvents;
      try {
        const masterPayload = await loadJson('/');
        const masterRows = getMasterRows(masterPayload);
        setDebug('master', 'yes');
        setDebug('master-count', String(masterRows.length));
        events = enrichTopEventsFromMaster(topEvents, masterRows);
      } catch (error) {
        setDebug('master', 'no');
        setDebug('master-count', '0');
      }
      setDebugTopDetails(events, topEvents);

      container.innerHTML = events.map((event) => {
        const title = titleForEvent(event);
        const location = pickPath(event, ['kraj', 'event.kraj', 'race.kraj', 'data.kraj', 'location', 'place', 'city', 'regija', 'Regija'], 'Slovenija');
        const region = pickPath(event, ['regija', 'event.regija', 'race.regija', 'data.regija', 'region'], '');
        const dateValue = pickPath(event, ['datum', 'event.datum', 'race.datum', 'data.datum', 'date', 'event_date', 'Datum']);
        const date = formatDate(dateValue);
        const votes = getTopEventVotes(event);
        const meta = joinParts([location, region && region !== location ? region : '']);
        const metaItems = [
          votes !== null ? `<span class="event-chip pill-orange">${escapeHtml(formatVoteCount(votes))}</span>` : '<span class="event-chip pill-orange">Glasovanje odprto</span>'
        ].filter(Boolean).join('');

        return `
          <article class="event-card">
            <div class="event-card-heading">
              <time class="event-card-date" datetime="${escapeHtml(dateValue)}" aria-label="${escapeHtml(date)}">${escapeHtml(formatDateBadge(dateValue))}</time>
              <h3>${escapeHtml(title)}</h3>
            </div>
            ${meta ? `<p>${escapeHtml(meta)}</p>` : ''}
            ${metaItems ? `<div class="event-details">${metaItems}</div>` : ''}
          </article>
        `;
      }).join('');
      setStatus('top', 'Lestvica je razvrščena po številu glasov. Pri izenačenem številu glasov imajo prednost bližnji prihajajoči teki.');
    } catch (error) {
      setDebug('top', 'no');
      setStatus('top', 'Seznam trenutno ni dosegljiv, zato ostaja nadomestni prikaz.');
    }
  }

  async function loadRecentUpdates() {
    const container = document.querySelector('[data-recent-updates]');
    if (!container) return;

    try {
      const payload = await loadJson('/recent_updates?days=7');
      const updates = toArray(payload).slice(0, 6);
      setDebug('recent', 'yes');
      setDebugRecentDetails(updates);

      if (!updates.length) {
        container.innerHTML = `
          <article class="update-card">
            <p>V zadnjih 7 dneh ni bilo novih javnih sprememb v koledarju.</p>
          </article>
        `;
        setStatus('updates', '');
        return;
      }

      container.innerHTML = updates.map((update) => {
        const title = pickPath(update, [
          'naziv_prireditve',
          'naziv',
          'event.naziv_prireditve',
          'event.naziv',
          'title',
          'name'
        ], 'Posodobitev koledarja');
        const eventDate = formatDate(pickPath(update, ['datum', 'event.datum', 'date', 'event_date', 'Datum']));
        const changed = formatDate(pickPath(update, ['zadnja_sprememba', 'zadnja_sprememba_podrobno', 'updated_at', 'updated', 'modified_at', 'changed_at', 'last_updated']));
        const location = pickPath(update, ['kraj', 'event.kraj', 'place', 'city', 'location'], '');
        const region = pickPath(update, ['regija', 'event.regija', 'region'], '');
        const updateType = pickPath(update, ['sprememba', 'vrsta_spremembe', 'change_type', 'change', 'status', 'type'], 'posodobljeno');
        const note = pickPath(update, ['opis', 'zadnja_sprememba_podrobno', 'opis_spremembe', 'summary', 'notes', 'note', 'opombe_javne'], '');
        const place = joinParts([location, region && region !== location ? region : '']);
        const meta = joinParts([place, eventDate ? `datum teka: ${eventDate}` : '', changed ? `posodobljeno: ${changed}` : '']);
        const summary = note || `Vnos je bil ${updateType}.`;

        return `
          <article class="update-card">
            <h3>${escapeHtml(title)}</h3>
            <p>${escapeHtml(summary)}</p>
            ${meta ? `<div class="event-meta"><span class="pill">${escapeHtml(meta)}</span></div>` : ''}
          </article>
        `;
      }).join('');
      setStatus('updates', '');
    } catch (error) {
      setDebug('recent', 'no');
      setStatus('updates', 'Zadnje posodobitve trenutno niso dosegljive, zato ostaja nadomestni prikaz.');
    }
  }

  if (enableApiDebug) createDebugPanel();
  loadStats();
  loadNearestEvents();
  loadTopEvents();
  loadRecentUpdates();
</script>
