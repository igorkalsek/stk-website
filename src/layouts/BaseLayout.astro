---
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import '../styles/global.css';

interface Props {
  title?: string;
  description?: string;
  lang?: string;
}

const {
  title = 'Slovenski Tekaški Koledar',
  description = 'Neodvisen koledar tekaških prireditev po Sloveniji.',
  lang = 'sl'
} = Astro.props;
const pageTitle = title === 'Slovenski Tekaški Koledar' ? title : `${title} | Slovenski Tekaški Koledar`;
---

<!doctype html>
<html lang={lang}>
  <head>
    <meta charset="UTF-8" />
    <meta name="description" content={description} />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="theme-color" content="#104050" />
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <title>{pageTitle}</title>
  </head>
  <body>
    <Header />
    <slot />
    <Footer />
  </body>
</html>
