---
import SocialLinks from './SocialLinks.astro';

interface FooterLink {
  href: string;
  label: string;
}

interface Props {
  lang?: 'sl' | 'en' | string;
}

const { lang = 'sl' } = Astro.props;
const isEnglish = lang === 'en';

const links: FooterLink[] = isEnglish ? [
  { href: '/en/find-races/', label: 'Find races' },
  { href: '/en/family-friendly-races/', label: 'Family-friendly races' },
  { href: '/en/group-runs/', label: 'Group runs' },
  { href: '/en/most-voted-races/', label: 'Most voted races' },
  { href: '/en/personal-calendar/', label: 'Personal calendar' },
  { href: '/en/stk-tekobot/', label: 'STK Tekobot' },
  { href: '/', label: 'Slovenščina' }
] : [
  { href: '/iskalnik-tekov/', label: 'Iskalnik tekov' },
  { href: '/druzinam-prijazni-teki/', label: 'Družinam prijazni teki' },
  { href: '/skupinski-teki/', label: 'Skupinski teki' },
  { href: '/najbolj-glasovani-teki/', label: 'Glasovani teki' },
  { href: '/osebni-koledar/', label: 'Osebni koledar' },
  { href: '/dodaj-ali-popravi-tek/', label: 'Dodajte ali popravite tek' },
  { href: '/stk-tekobot/', label: 'STK Tekobot' },
  { href: '/o-projektu-in-zasebnost/', label: 'O projektu in zasebnost' },
  { href: '/en/', label: 'English' }
];
---

<footer class="site-footer">
  <div class="container footer-inner">
    <div class="footer-column footer-identity">
      <div class="footer-brand">
        <img class="footer-logo" src="/stk-logo.jpeg" alt="Slovenski Tekaški Koledar" />
        <p class="footer-title">Slovenski Tekaški Koledar</p>
      </div>
      <p>{isEnglish ? 'An independent overview of running events in Slovenia.' : 'Neodvisen pregled tekaških prireditev po Sloveniji.'}</p>
    </div>

    <div class="footer-column footer-info">
      <p>{isEnglish ? 'Race information is updated regularly, but it is provided for orientation only. Before registering, always check the official race announcement or the organiser’s website.' : 'Podatki se sproti posodabljajo, vendar so informativne narave. Pred prijavo vedno preverite uradni razpis ali stran organizatorja.'}</p>

    </div>

    <nav class="footer-column footer-links" aria-label={isEnglish ? 'Footer links' : 'Povezave v nogi'}>
      <h2 class="footer-heading">{isEnglish ? 'Links' : 'Povezave'}</h2>
      <div class="footer-link-list">
        {links.map((link) => (
          <a href={link.href}>
            <span>{link.label}</span>
          </a>
        ))}
      </div>
    </nav>

    <div class="footer-column footer-contact">
      <h2 class="footer-heading">{isEnglish ? 'Contact' : 'Kontakt'}</h2>
      <a href="mailto:tekaski.koledar@gmail.com">tekaski.koledar@gmail.com</a>
      <div class="footer-social-block">
        <p class="footer-social-heading" id={isEnglish ? 'footer-social-title-en' : 'footer-social-title'}>{isEnglish ? 'Social' : 'Družbena omrežja'}</p>
        <SocialLinks lang={lang} variant="footer" labelledby={isEnglish ? 'footer-social-title-en' : 'footer-social-title'} />
      </div>
    </div>
  </div>
  <div class="container footer-bottom">© 2026 Slovenski Tekaški Koledar</div>
</footer>
