---
interface NavItem {
  href: string;
  label: string;
}

interface Props {
  navItems?: NavItem[];
  brandHref?: string;
  brandLabel?: string;
  navLabel?: string;
  menuLabel?: string;
}

const defaultNavItems = [
  { href: '/', label: 'Domov' },
  { href: '/iskalnik-tekov/', label: 'Iskalnik' },
  { href: '/druzinam-prijazni-teki/', label: 'Družinam prijazni' },
  { href: '/skupinski-teki/', label: 'Skupinski' },
  { href: '/najbolj-glasovani-teki/', label: 'Glasovani' },
  { href: '/osebni-koledar/', label: 'Koledar' },
  { href: '/stk-tekobot/', label: 'Tekobot' }
];

const {
  navItems = defaultNavItems,
  brandHref = '/',
  brandLabel = 'Slovenski Tekaški Koledar - domov',
  navLabel = 'Glavna navigacija',
  menuLabel = 'Meni'
} = Astro.props;

const languagePairs = new Map<string, string>([
  ['/', '/en/'],
  ['/iskalnik-tekov/', '/en/find-races/'],
  ['/druzinam-prijazni-teki/', '/en/family-friendly-races/'],
  ['/skupinski-teki/', '/en/group-runs/'],
  ['/najbolj-glasovani-teki/', '/en/most-voted-races/'],
  ['/osebni-koledar/', '/en/personal-calendar/'],
  ['/stk-tekobot/', '/en/stk-tekobot/']
]);

const normalizePath = (path: string) => (path === '/' ? '/' : `${path.replace(/\/$/, '')}/`);
const currentPath = normalizePath(Astro.url.pathname);
const isEnglishPage = currentPath.startsWith('/en/');
const currentSlovenianPath = isEnglishPage
  ? [...languagePairs.entries()].find(([, englishPath]) => englishPath === currentPath)?.[0]
  : currentPath;
const currentEnglishPath = isEnglishPage ? currentPath : languagePairs.get(currentPath);
const slovenianHref = currentSlovenianPath && languagePairs.has(currentSlovenianPath) ? currentSlovenianPath : '/';
const englishHref = currentEnglishPath ?? '/en/';
---

<header class="site-header">
  <div class="container header-inner">
    <a class="brand" href={brandHref} aria-label={brandLabel}>
      <img class="brand-logo" src="/stk-logo.jpeg" alt="Slovenski Tekaški Koledar" />
      <span class="brand-name">Slovenski Tekaški Koledar</span>
    </a>
    <button class="nav-toggle" type="button" aria-expanded="false" aria-controls="site-navigation">
      {menuLabel}
    </button>
    <nav id="site-navigation" class="site-nav" data-open="false" aria-label={navLabel}>
      {navItems.map((item) => (
        <a href={item.href} aria-current={currentPath === normalizePath(item.href) ? 'page' : undefined}>
          {item.label}
        </a>
      ))}
      <div class="language-switcher" aria-label={isEnglishPage ? 'Language switcher' : 'Izbira jezika'}>
        <a
          class:list={["language-link", { 'is-active': !isEnglishPage }]}
          href={slovenianHref}
          aria-label="Switch to Slovenian"
          aria-current={!isEnglishPage ? 'true' : undefined}
        >🇸🇮 SL</a>
        <span class="language-separator" aria-hidden="true">|</span>
        <a
          class:list={["language-link", { 'is-active': isEnglishPage }]}
          href={englishHref}
          aria-label="Switch to English"
          aria-current={isEnglishPage ? 'true' : undefined}
        >🇬🇧 EN</a>
      </div>
    </nav>
  </div>
</header>

<script>
  const toggle = document.querySelector('.nav-toggle');
  const nav = document.querySelector('.site-nav');

  toggle?.addEventListener('click', () => {
    const isOpen = nav?.getAttribute('data-open') === 'true';
    nav?.setAttribute('data-open', String(!isOpen));
    toggle.setAttribute('aria-expanded', String(!isOpen));
  });
</script>
